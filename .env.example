# Optional for real LangGraph persistence. The starter uses memory/mock by default.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph_lab
CHECKPOINTER=memory
LOG_LEVEL=INFO

# LangSmith tracing (optional) — set these to send traces to LangSmith Studio
# Get your API key at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_key_here
LANGCHAIN_PROJECT=day08-lab
